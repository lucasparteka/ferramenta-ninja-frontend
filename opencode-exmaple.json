{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"instructions": ["CLAUDE.md", "AGENTS.md"],
	"provider": {
		"moonshot": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Moonshot",
			"options": {
				"baseURL": "https://api.moonshot.ai/v1",
				"apiKey": "..."
			},
			"models": {
				"kimi-k2.6": {
					"name": "Kimi K2.6",
					"options": {
						"thinking": { "type": "disabled" }
					}
				}
			}
		}
	},
	"mcp": {
		"code-graph": {
			"type": "local",
			"command": [
				"C:/Users/lucas/AppData/Local/Programs/Python/Python313/Scripts/cgc",
				"mcp",
				"start"
			],
			"enabled": true
		},
		"context7": {
			"type": "local",
			"command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "..."],
			"enabled": false
		},
		"codebase-memory": {
			"type": "local",
			"command": ["C:/Users/lucas/.local/bin/codebase-memory-mcp"],
			"enabled": true
		}
	},
	"agent": {
		"plan": {
			"mode": "primary",
			"model": "moonshot/kimi-k2.6",
			"temperature": 0.1,
			"description": "Agente de planejamento. Analise o que foi pedido, localize os arquivos com code-graph, e apresente um plano curto (arquivo > acao). Sem modificar arquivos. Sem explorar alternativas nao pedidas. Siga CLAUDE.md e AGENTS.md.",
			"permission": {
				"read": "allow",
				"grep": "allow",
				"glob": "allow",
				"list": "allow",
				"task": "allow",
				"edit": "deny",
				"bash": "deny",
				"write": "deny",
				"external_directory": "deny"
			}
		},
		"build": {
			"mode": "primary",
			"model": "moonshot/kimi-k2.6",
			"temperature": 0.1,
			"description": "Agente de execucao. Implemente o que foi pedido, confirme em uma frase, passe ao proximo item. Nao reanalise, nao refatore o que nao foi pedido, nao repita tool calls ja feitas. Se algo fugir do plano, pare e avise. Siga CLAUDE.md e AGENTS.md.",
			"permission": {
				"read": "allow",
				"edit": "allow",
				"bash": "allow",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"task": "allow",
				"write": "allow",
				"external_directory": "ask"
			}
		}
	}
}

{
	"$schema": "https://opencode.ai/config.json",

	// ─────────────────────────────────────────────
	// PROVIDER: Moonshot AI (Kimi K2.6)
	// ─────────────────────────────────────────────
	"provider": {
		"moonshot": {
			"options": {
				"baseURL": "https://api.moonshot.ai/v1",

				// Timeout total da requisição: 3 minutos
				// Se o modelo travar e não responder nada, aborta após 180s
				"timeout": 180000,

				// Timeout entre chunks de streaming: 15 segundos
				// Se ficar 15s sem receber nenhum chunk, aborta
				// (isso pega o caso de "ficar pensando sem retornar nada")
				"chunkTimeout": 15000
			},
			"models": {
				"kimi-k2.6": {
					"name": "Kimi K2.6",
					"limit": {
						"context": 100000,
						"output": 8192
					},
					"options": {
						"thinking": {
							"type": "disabled"
						}
					}
				}
			}
		}
	},

	// ─────────────────────────────────────────────
	// MODELO PADRÃO
	// ─────────────────────────────────────────────
	"model": "moonshot/kimi-k2.6",

	// Usa o mesmo modelo para tarefas leves (título, resumo)
	// pois não temos um modelo menor no Moonshot
	"small_model": "moonshot/kimi-k2.6",

	// ─────────────────────────────────────────────
	// TOOLS: desativar o que gera chamadas desnecessárias
	// ─────────────────────────────────────────────
	"tools": {
		"todowrite": false,
		"webfetch": false,
		"websearch": false
	},

	// ─────────────────────────────────────────────
	// AGENTS: limitar steps e configurar comportamento
	// ─────────────────────────────────────────────
	"agent": {
		"build": {
			"mode": "primary",
			"model": "moonshot/kimi-k2.6",
			"steps": 15,
			"temperature": 0.6,
			"permission": {
				"edit": "allow",
				"bash": "allow",
				// Pede aprovação antes de ler/buscar — evita leituras desnecessárias
				"read": "ask",
				"grep": "ask",
				"glob": "ask"
			}
		},
		"plan": {
			"mode": "primary",
			"model": "moonshot/kimi-k2.6",
			"steps": 10,
			"temperature": 0.4,
			"permission": {
				"edit": "deny",
				"bash": "deny",
				// No plan, read/grep/glob também pedem aprovação
				"read": "ask",
				"grep": "ask",
				"glob": "ask"
			}
		},
		"explore": {
			"mode": "subagent",
			"model": "moonshot/kimi-k2.6",
			"steps": 8,
			"temperature": 0.3,
			"permission": {
				"edit": "deny",
				"bash": "deny",
				"read": "ask",
				"grep": "ask",
				"glob": "ask"
			}
		},
		"general": {
			"mode": "subagent",
			"model": "moonshot/kimi-k2.6",
			"steps": 10,
			"temperature": 0.5,
			"permission": {
				"read": "ask",
				"grep": "ask",
				"glob": "ask"
			}
		}
	},

	// ─────────────────────────────────────────────
	// COMPACTION: compactar contexto agressivamente
	// ─────────────────────────────────────────────
	"compaction": {
		"auto": true,
		"prune": true,
		"threshold": 0.5,
		"maxContext": 100000
	},

	// ─────────────────────────────────────────────
	// SNAPSHOT
	// ─────────────────────────────────────────────
	"snapshot": true,

	// ─────────────────────────────────────────────
	// AUTOUPDATE
	// ─────────────────────────────────────────────
	"autoupdate": true,

	// ─────────────────────────────────────────────
	// MCP SERVERS
	// ─────────────────────────────────────────────
	"mcp": {
		"code-review-graph": {
			"type": "local",
			"command": ["uvx", "code-review-graph", "serve"],
			"enabled": true,
			"timeout": 10000
		}
	},

	// ─────────────────────────────────────────────
	// PERMISSÕES PADRÃO (fallback global)
	// ─────────────────────────────────────────────
	"permission": {
		"edit": "allow",
		"bash": "allow",
		// Leitura/busca: pedir aprovação globalmente
		"read": "ask",
		"grep": "ask",
		"glob": "ask",
		"todowrite": "deny",
		"webfetch": "deny",
		"websearch": "deny",

		// MCP do code-review-graph: liberado (queries são baratas)
		"code-review-graph_*": "allow"
	}
}

{
	"$schema": "https://opencode.ai/config.json",
	"model": "opencode-go/deepseek-v4-pro",
	"small_model": "opencode-go/deepseek-v4-flash",
	"tools": {
		"todowrite": false
	},
	"formatter": {
		"biome": {
			"command": ["npx", "biome", "format", "--write", "$FILE"],
			"environment": {
				"NODE_ENV": "development"
			},
			"extensions": [".js", ".ts", ".jsx", ".tsx"]
		}
	},
	"agent": {
		"plan": {
			"mode": "primary",
			"model": "opencode-go/deepseek-v4-pro",
			"steps": 10,
			"permission": {
				"edit": "deny",
				"bash": "deny",
				"read": "allow",
				"grep": "allow",
				"glob": "allow"
			}
		},
		"build": {
			"mode": "primary",
			"model": "opencode-go/kimi-k2.6",
			"steps": 20,
			"permission": {
				"edit": "allow",
				"bash": "allow",
				"read": "allow",
				"grep": "allow",
				"glob": "allow"
			}
		},
		"explore": {
			"mode": "subagent",
			"model": "opencode-go/deepseek-v4-flash",
			"steps": 8,
			"permission": {
				"edit": "deny",
				"bash": "deny",
				"read": "allow",
				"grep": "allow",
				"glob": "allow"
			}
		},
		"general": {
			"mode": "subagent",
			"model": "opencode-go/deepseek-v4-pro",
			"steps": 10,
			"permission": {
				"read": "allow",
				"grep": "allow",
				"glob": "allow"
			}
		}
	},
	"compaction": {
		"auto": true,
		"prune": true
	},
	"snapshot": true,
	"autoupdate": true,
	"mcp": {
		"code-review-graph": {
			"type": "local",
			"command": ["uvx", "code-review-graph", "serve"],
			"enabled": true,
			"timeout": 10000
		}
	},
	"lsp": {
		"typescript": {
			"command": [
				"node_modules/.bin/typescript-language-server.CMD",
				"--stdio"
			],
			"extensions": ["ts", "tsx"]
		}
	},
	"permission": {
		"edit": "allow",
		"bash": "allow",
		"read": "ask",
		"grep": "ask",
		"glob": "ask",
		"todowrite": "deny",
		"code-review-graph_*": "allow"
	}
}

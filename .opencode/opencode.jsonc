{
	"$schema": "https://opencode.ai/config.json",
	"permission": {
		"lsp": "allow"
	},
	"lsp": {
		"typescript": {
			"command": [
				"node",
				"node_modules/typescript-language-server/lib/cli.mjs",
				"--stdio"
			]
		}
	},
	"mcp": {
		"jcodemunch": {
			"enabled": true,
			"type": "local",
			"command": "jcodemunch-mcp",
			"args": []
		},
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true,
			"headers": {
				"CONTEXT7_API_KEY": "ctx7sk-cf5007fb-7461-4db1-af83-c0e8e65134d9"
			}
		}
	}
}
